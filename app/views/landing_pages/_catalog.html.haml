= display_search_boxes('catalog')

.row
  .landing_main.col-sm-8

    .title Catalog

    = render partial: '/datasource_warning', locals: {warning: warning}

    %p Search Columbia's catalog of over 18 million items for:
    %ul
      %li books
      %li journals and newspaper titles
      %li audio and video recordings
      %li scores
      %li archival collections
      %li databases
      %li government documents
      %li maps and atlases

    %p For more targeted results, try an #{content_tag(:a, 'Advanced Search', class: 'advanced_search_toggle_bis', href: '#')}, or narrow your results by format, date, and other options on the search results page.

    %p To find individual articles, try searching #{datasource_switch_link('Articles+', 'articles')}.


  .landing_side.col-sm-4
    .well.sidebar-nav
      .nav
        %ul.nav.nav-list
          %li.nav-header Guide
          %li=link_to 'Search Tips', 'https://blogs.cul.columbia.edu/clio/guides/catalog-guide/', :target => '_blank'

          %li.nav-divider

        %ul.nav.nav-list
          %li.nav-header Other Useful Catalogs
          %li= link_to 'Course Reserves', 'https://resolver.library.columbia.edu/lweb0182', :target => '_blank'
          %li= link_to 'Borrow Direct', 'https://resolver.library.columbia.edu/lweb0012', :target => '_blank'
          %li= link_to 'Interlibrary Loan (ILL)', 'https://resolver.library.columbia.edu/lweb0014', :target => '_blank'
          %li= link_to 'WorldCat', 'https://resolver.library.columbia.edu/AMS7418', :target => '_blank'
          %li= link_to 'Teachers College Catalog', 'https://resolver.library.columbia.edu/AMS8580', :target => '_blank'
          %li= link_to 'Numeric Data Catalog', 'https://resolver.library.columbia.edu/APZ9144', :target => '_blank'
          %li= link_to 'Spatial Data Catalog', 'https://resolver.library.columbia.edu/clio6269876', :target => '_blank'



